---
---
<section
  style="
    padding: 5rem 2rem 4rem;
    text-align: center;
    border-bottom: 1px solid #3a3a3a;
    position: relative;
    overflow: hidden;
  "
>
  <!-- Background glow effect inspired by Cookielab concentric circles -->
  <div
    aria-hidden="true"
    style="
      position:absolute;inset:0;pointer-events:none;
      background: radial-gradient(ellipse 60% 55% at 50% 50%, rgba(255,205,104,0.06) 0%, transparent 70%);
    "
  ></div>

  <div style="position:relative;z-index:1;max-width:800px;margin:0 auto;">
    <!-- Eyebrow label -->
    <p style="
      display:inline-block;
      background:#FFCD6820;
      border:1px solid #FFCD6840;
      color:#FFCD68;
      font-size:0.8rem;
      font-weight:600;
      letter-spacing:0.1em;
      text-transform:uppercase;
      padding:0.35rem 1rem;
      border-radius:999px;
      margin-bottom:1.5rem;
    ">Open Data · Community Project</p>

    <h1 style="
      font-family:'Raleway','Arial Black',sans-serif;
      font-size:clamp(3rem,8vw,5.5rem);
      font-weight:900;
      letter-spacing:-0.03em;
      line-height:1;
      margin-bottom:1.25rem;
      color:#F2F0E5;
    ">
      Dev<span style="color:#FFCD68;">Drift</span>
    </h1>

    <p style="
      font-size:clamp(1rem,2.5vw,1.3rem);
      color:#94a3b8;
      line-height:1.6;
      margin-bottom:0.75rem;
    ">
      How the programming profession changed · 1970–2026
    </p>
    <p style="
      font-size:0.95rem;
      color:#64748b;
      line-height:1.6;
      max-width:560px;
      margin:0 auto 2.5rem;
    ">
      The skills expected from senior developers, decade by decade.
      Validated against Stack Overflow Dev Surveys, JetBrains Dev Ecosystem, DORA, CNCF, and Martin Fowler.
    </p>

    <!-- CTA anchors -->
    <div style="display:flex;gap:0.75rem;justify-content:center;flex-wrap:wrap;">
      <a
        href="#category-trends"
        style="
          display:inline-block;
          background:transparent;
          color:#F2F0E5;
          border:1.5px solid #3a3a3a;
          font-weight:600;
          font-size:0.95rem;
          padding:0.65rem 1.5rem;
          border-radius:999px;
          text-decoration:none;
          transition:border-color 0.15s;
        "
        onmouseover="this.style.borderColor='#FFCD68'"
        onmouseout="this.style.borderColor='#3a3a3a'"
      >Skill Radar</a>
      <a
        href="#skills-timeline"
        style="
          display:inline-block;
          background:transparent;
          color:#F2F0E5;
          border:1.5px solid #3a3a3a;
          font-weight:600;
          font-size:0.95rem;
          padding:0.65rem 1.5rem;
          border-radius:999px;
          text-decoration:none;
          transition:border-color 0.15s;
        "
        onmouseover="this.style.borderColor='#FFCD68'"
        onmouseout="this.style.borderColor='#3a3a3a'"
      >Skills Timeline</a>
      <a
        href="#population"
        style="
          display:inline-block;
          background:transparent;
          color:#F2F0E5;
          border:1.5px solid #3a3a3a;
          font-weight:600;
          font-size:0.95rem;
          padding:0.65rem 1.5rem;
          border-radius:999px;
          text-decoration:none;
          transition:border-color 0.15s;
        "
        onmouseover="this.style.borderColor='#FFCD68'"
        onmouseout="this.style.borderColor='#3a3a3a'"
      >Dev Population</a>
      <a
        href="#complexity"
        style="
          display:inline-block;
          background:transparent;
          color:#F2F0E5;
          border:1.5px solid #3a3a3a;
          font-weight:600;
          font-size:0.95rem;
          padding:0.65rem 1.5rem;
          border-radius:999px;
          text-decoration:none;
          transition:border-color 0.15s;
        "
        onmouseover="this.style.borderColor='#FFCD68'"
        onmouseout="this.style.borderColor='#3a3a3a'"
      >Complexity</a>
    </div>
  </div>
</section>
