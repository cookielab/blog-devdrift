---
export interface Props {
  id: string;
  title: string;
  subtitle?: string;
}
const { id, title, subtitle } = Astro.props;
---
<section
  id={id}
  style="padding:3.5rem 2rem;max-width:1400px;margin:0 auto;"
>
  <div style="margin-bottom:1.5rem;">
    <h2 style="
      font-family:'Raleway','Arial Black',sans-serif;
      font-size:clamp(1.5rem,4vw,2.2rem);
      font-weight:800;
      letter-spacing:-0.02em;
      color:#F2F0E5;
      margin-bottom:0.35rem;
    ">{title}</h2>
    {subtitle && (
      <p style="color:#64748b;font-size:0.95rem;">{subtitle}</p>
    )}
  </div>

  <div style="
    background:#252525;
    border:1px solid #3a3a3a;
    border-radius:1rem;
    padding:1.5rem 1.5rem 1rem;
    position:relative;
  ">
    <slot />
  </div>
</section>
