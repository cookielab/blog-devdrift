---
export interface Props {
  id: string;
  title: string;
  subtitle?: string;
}
const { id, title, subtitle } = Astro.props;
---

<section id={id} class="chart-section">
  <div class="chart-header">
    <h2>{title}</h2>
    {subtitle && <p class="chart-subtitle">{subtitle}</p>}
  </div>

  <slot name="extra" />

  <div class="chart-card">
    <slot />
  </div>
</section>

<style>
  .chart-section {
    padding: 3.5rem 2rem;
    max-width: 1400px;
    margin: 0 auto;
  }
  .chart-header {
    max-width: 65ch;
    margin: 0 auto 1.5rem;
  }
  .chart-header h2 {
    font-family: 'Raleway', 'Arial Black', sans-serif;
    font-size: clamp(1.5rem, 4vw, 2.2rem);
    font-weight: 800;
    letter-spacing: -0.02em;
    color: #F2F0E5;
    margin-bottom: 0.35rem;
  }
  .chart-subtitle {
    color: #94a3b8;
    line-height: 1.7;
    font-size: 1rem;
  }
  .chart-card {
    background: #252525;
    border: 1px solid #3a3a3a;
    border-radius: 1rem;
    padding: 1.5rem 1.5rem 1rem;
    position: relative;
  }
  @media (max-width: 768px) {
    .chart-section {
      padding: 2rem 0;
    }
    .chart-header {
      padding: 0 2rem;
    }
    .chart-card {
      padding: 1.5rem;
      border-radius: 0;
      border-left: none;
      border-right: none;
      overflow: hidden;
    }
  }
</style>
